# ═══════════════════════════════════════════════════════════════
# 24xRaven SMS Bot - Environment Variables Example
# Developed by ✘ 𝙍𝘼𝙑𝙀𝙉
# 
# Instructions:
# 1. Copy this file and rename it to '.env'
# 2. Fill in your actual values
# 3. Never commit .env to version control
# ═══════════════════════════════════════════════════════════════

# Telegram Bot Token (Get from @BotFather)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Admin Telegram IDs (comma separated)
ADMIN_IDS=0000000000

# Chat IDs for notifications (comma separated)
CHAT_IDS=YOUR_CHAT_ID_HERE

# iVasms Credentials
IVASMS_USERNAME=your_email@example.com
IVASMS_PASSWORD=your_password

# Site Credentials
SITE_USERNAME=your_username
SITE_PASSWORD=your_password

# ═══════════════════════════════════════════════════════════════
# Optional Settings
# ═══════════════════════════════════════════════════════════════

# Database path
DB_PATH=bot.db

# Refresh interval (seconds)
REFRESH_INTERVAL=2

# Request timeout (seconds)
TIMEOUT=100

# Max retries
MAX_RETRIES=5

# Retry delay (seconds)
RETRY_DELAY=5
